{
  "name": "crm-web-vue",
  "version": "1.0.0",
  "description": "A vue project with Element UI & axios & iconfont & permission control & lint",
  "scripts": {
    "dev": "webpack-dev-server --inline --progress --config build/webpack.dev.conf.js --host localhost",
    "start": "npm run dev",
    "build": "node build/build.js",
    "build:report": "npm_config_report=true npm run build",
    "lint": "eslint --ext .js,.vue src",
    "test": "npm run lint",
    "svgo": "svgo -f src/icons/svg --config=src/icons/svgo.yml",
    "build--test": "cross-env NODE_ENV=testing env_config=test node build/build.js",
    "build--uat": "cross-env NODE_ENV=uating env_config=uat node build/build.js",
    "build--idc": "cross-env NODE_ENV=idcing env_config=idc node build/build.js",
    "build--prod": "cross-env NODE_ENV=production env_config=prod node build/build.js"
  },
  "dependencies": {
    "@dagrejs/graphlib": "^2.1.4",
    "activiti-bpmn-moddle": "^4.4.0",
    "axios": "0.18.0",
    "bpmn-js": "^7.4.1",
    "bpmn-js-properties-panel": "^0.37.5",
    "camunda-bpmn-moddle": "^4.5.0",
    "chrom": "^0.0.0",
    "dayjs": "^1.10.7",
    "echarts": "^4.2.1",
    "el-table-infinite-scroll": "^1.0.10",
