    "element-ui": "^2.15.14",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.0",
    "fuse.js": "^6.4.1",
    "highlight.js": "^10.1.2",
    "html2canvas": "^1.0.0-alpha.12",
    "js-cookie": "2.2.0",
    "jspdf": "^1.4.1",
    "mathjs": "^9.3.2",
    "moment": "^2.29.1",
    "node-sass": "^4.14.1",
    "normalize.css": "7.0.0",
    "nprogress": "0.2.0",
    "screenfull": "^5.0.2",
    "scss": "^0.2.4",
    "scss-loader": "0.0.1",
    "stompjs": "^2.3.3",
    "sweetalert": "^2.1.2",
