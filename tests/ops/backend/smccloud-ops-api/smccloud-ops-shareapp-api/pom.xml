                    <!--<out>target/docs</out>-->
                    <!--<dependency>../smccloud-ops-api/smccloud-ops-shareapp-api/src/main/java/com/smc/smccloud/service</dependency>-->
                    <!--<version>1.0.0</version>-->
                    <!--<description>-->
                        <!--=========-->
                    <!--</description>-->
                <!--</configuration>-->
            </plugin>
        </plugins>
    </build>
</project>
